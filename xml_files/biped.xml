<mujoco model="simple_biped">
    <compiler angle="degree"/>

    <option timestep="0.002"/>

    <worldbody>
        <light name="sun" directional="true" dir="-1 -1 -2" castshadow="true"/>

        <!-- Ground plane -->
        <geom name="ground" type="plane" size="5 5 0.1" rgba="0.2 0.3 0.4 1"/>
        <!-- Obstacle box -->
        <geom
            name="obstacle_box"
            type="box"
            pos="-3 0 0.075"
            size="0.5 0.2 0.075"
            rgba="0.6 0.6 0.6 1"/>
        
        <geom
            name="obstacle_box2"
            type="box"
            pos="-12 0 0.075"
            size="1.5 0.2 0.075"
            rgba="0.6 0.6 0.6 1"/>

        <geom
            name="obstacle_box3"
            type="box"
            pos="-12 0 0.2"
            size="1.0 0.2 0.075"
            rgba="0.6 0.6 0.6 1"/>
        
        <geom
            name="obstacle_box4"
            type="box"
            pos="-12 0 0.35"
            size="0.5 0.2 0.075"
            rgba="0.6 0.6 0.6 1"/>

        <geom
            name="obstacle_box5"
            type="box"
            pos="-16 0 0.075"
            size="1 0.2 0.075"
            rgba="0.6 0.6 0.6 1"/>

        <geom
            name="obstacle_box6"
            type="box"
            pos="-16.5 0 0.2"
            size="0.5 0.2 0.075"
            rgba="0.6 0.6 0.6 1"/>
        
        
        <!-- Torso -->
        <body name="torso" pos="0 0 1.5">
            <geom type="capsule" size="0.1 0.3" mass="8" rgba="0.8 0.2 0.2 1"/>
            <joint name="rootx" type="slide" axis="1 0 0"/>
            <joint name="rootz" type="slide" axis="0 0 1"/>
            <joint name="rooty" type="hinge" axis="0 1 0"/>
            
            <!-- Right thigh -->
            <body name="right_thigh" pos="0 -0.1 -0.3">
                <joint name="right_hip" type="hinge" axis="0 1 0" range="-60 60"/>
                <geom type="capsule" size="0.07 0.3" mass="1" rgba="0.2 0.2 0.8 1" pos="0 0 -0.3"/>
                <!-- Right shin -->
                <body name="right_shin" pos="0 0 -0.6">
                    <joint name="right_knee" type="hinge" axis="0 1 0" range="-120 -5"/>
                    <geom name="right_shin_geom" type="capsule" size="0.06 0.3" mass="1" rgba="0.2 0.2 0.8 1" pos="0 0 -0.3"/>
                </body>
            </body>

            <!-- Left thigh -->
            <body name="left_thigh" pos="0 0.1 -0.3">
                <joint name="left_hip" type="hinge" axis="0 1 0" range="-60 60"/>
                <geom type="capsule" size="0.07 0.3" mass="1" rgba="0.2 0.8 0.2 1" pos="0 0 -0.3"/>
                <!-- Left shin -->
                <body name="left_shin" pos="0 0 -0.6">
                    <joint name="left_knee" type="hinge" axis="0 1 0" range="-120 -5"/>
                    <geom name="left_shin_geom" type="capsule" size="0.06 0.3" mass="1" rgba="0.2 0.8 0.2 1" pos="0 0 -0.3"/>
                </body>
            </body>
        </body>
    </worldbody>

    <actuator>
        <velocity joint="right_hip" kv="20"/>
        <velocity joint="right_knee" kv="20"/>
        <velocity joint="left_hip" kv="20"/>
        <velocity joint="left_knee" kv="20"/>
    </actuator>
    
</mujoco>