<mujoco model="simple_biped">
    <compiler angle="degree"/>

    <option timestep="0.0005"/>

    <worldbody>
        <light name="sun" directional="true" dir="-1 -1 -2" castshadow="true"/>

        <!-- Ground plane -->
        <geom name="ground" type="plane" size="50 50 0.1" rgba="0.2 0.3 0.4 1"/>
        <!-- Obstacle box -->
        <geom
            name="obstacle_box"
            type="box"
            pos="-4 0 0.075"
            size="0.5 4.2 0.075"
            rgba="0.6 0.6 0.6 1"
            euler="0 10 0"/>

        <geom
            name="obstacle_box_2"
            type="box"
            pos="-8 0 0.075"
            size="0.5 4.2 0.075"
            rgba="0.6 0.6 0.6 1"
            euler="0 10 0"/>


        <!-- Torso -->
        <body name="torso" pos="0 0 1.6">
            <geom type="capsule" size="0.1 0.3" mass="8" rgba="0.8 0.2 0.2 1"/>
            <joint type="free"/>
            

            <!-- Right leg -->
            <body name="right_hip_z" pos="0 -0.05 -0.25">
                <joint name="right_hip_z_j" type="hinge" axis="0 0 1" range="-20 20"/>
                <geom type="capsule" size="0.07 0.025" mass="0.1" rgba="0.2 0.2 0.8 1" pos="0 0.0 -0.025"  euler="-0 0 0" contype="0" conaffinity="0"/>
                <body name="right_hip_y" pos="0 -0.00 -0.05">
                    <joint name="right_hip_y_j" type="hinge" axis="1 0 0" range="-20 20"/>
                    <geom type="capsule" size="0.07 0.025" mass="0.1" rgba="0.2 0.2 0.8 1" pos="0 -0.025 0.0"  euler="90 0 0" contype="0" conaffinity="0"/>
                    <body name="right_thigh" pos="0 -0.05 -0.0">
                        <joint name="right_hip" type="hinge" axis="0 1 0" range="-60 60"/>
                        <geom type="capsule" size="0.07 0.3" mass="1" rgba="0.2 0.2 0.8 1" pos="0 0 -0.3" contype="0" conaffinity="0"/>
                        <!-- Right shin -->
                        <body name="right_shin" pos="0 0 -0.6">
                            <joint name="right_knee" type="hinge" axis="0 1 0" range="-120 -5"/>
                            <geom name="right_shin_geom" type="capsule" size="0.06 0.3" mass="1" rgba="0.2 0.2 0.8 1" pos="0 0 -0.3"/>
                            <body name="right_foot" pos="0 0 -0.6">
                                <joint name="right_foot_j" type="hinge" axis="0 1 0" range="-60 60"/>
                                <geom name="right_foot_geom" type="capsule" size="0.06 0.08" mass="0.1" rgba="0.2 0.2 0.8 1" pos="0 0 -0.0" euler="-0 90 0"/>
                            </body>
                        </body>
                    </body>
                </body>
            </body>
            <!-- Left leg -->
            <body name="left_hip_z" pos="0 0.05 -0.25">
                <joint name="left_hip_z_j" type="hinge" axis="0 0 1" range="-20 20"/>
                <geom type="capsule" size="0.07 0.025" mass="0.1" rgba="0.2 0.8 0.2 1" pos="0 0.0 -0.025"  euler="-0 0 0" contype="0" conaffinity="0"/>
                <body name="left_hip_y" pos="0 0.0 -0.05">
                    <joint name="left_hip_y_j" type="hinge" axis="1 0 0" range="-20 20"/>
                    <geom type="capsule" size="0.07 0.025" mass="0.1" rgba="0.2 0.8 0.2 1" pos="0 0.025 0.0"  euler="90 0 0" contype="0" conaffinity="0"/>
                    <!-- Left thigh -->
                    <body name="left_thigh" pos="0 0.05 -0.0">
                        <joint name="left_hip" type="hinge" axis="0 1 0" range="-120 120"/>
                        <geom type="capsule" size="0.07 0.3" mass="1" rgba="0.2 0.8 0.2 1" pos="0 0 -0.3" contype="0" conaffinity="0"/>
                        <!-- Left shin -->
                        <body name="left_shin" pos="0 0 -0.6">
                            <joint name="left_knee" type="hinge" axis="0 1 0" range="-120 -5"/>
                            <geom name="left_shin_geom" type="capsule" size="0.06 0.3" mass="1" rgba="0.2 0.8 0.2 1" pos="0 0 -0.3"/>
                            <body name="left_foot" pos="0 0 -0.6">
                                <joint name="left_foot_j" type="hinge" axis="0 1 0" range="-60 60"/>
                                <geom name="left_foot_geom" type="capsule" size="0.06 0.08" mass="0.1" rgba="0.2 0.2 0.8 1" pos="0 0 -0.0" euler="-0 90 0"/>
                            </body>
                        </body>
                    </body>
                </body>
            </body>
        </body>
    </worldbody>

    <actuator>
        <velocity joint="right_hip_z_j" kv="15"/>
        <velocity joint="right_hip_y_j" kv="30"/>
        <velocity joint="right_hip" kv="30"/>
        <velocity joint="right_knee" kv="30"/>
        <velocity joint="right_foot_j" kv="0.1"/>

        <velocity joint="left_hip_z_j" kv="15"/>
        <velocity joint="left_hip_y_j" kv="30"/>
        <velocity joint="left_hip" kv="30"/>
        <velocity joint="left_knee" kv="30"/>
        <velocity joint="left_foot_j" kv="0.1"/>
    </actuator>
    
</mujoco>